<UserControl x:Class="Diplomska.CherryFrame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="600" Width="1100" Background="Black">
    <Grid>
        <!-- Background Gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#111" Offset="0"/>
                <GradientStop Color="#222" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Height="180" VerticalAlignment="Top" ClipToBounds="True">
            <Image Source="C:\Projects\CherryMedia\CherryMedia\CherryMediaFiles\Pictures/herobanner.jpg"
            Stretch="UniformToFill"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Opacity="1.0"/>
            
            <Button Content="Nazaj" Width="100" Height="35"
                    HorizontalAlignment="Left" VerticalAlignment="Top" Margin="15"
                    Click="Back_Click"/>

            
        </Grid>
        <!-- Search and Filter Bar -->
        <Grid HorizontalAlignment="Stretch" Margin="10,210,10,0" VerticalAlignment="Top" Height="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
                
            </Grid.ColumnDefinitions>

            <!-- Search Bar -->
            <TextBox x:Name="SearchBox" Width="300" Height="30" Foreground="White"
         Background="#222" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"
         GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus"
         TextChanged="SearchBox_TextChanged"/>

            <TextBlock Name="Placeholder" Text="Search for movies..." Foreground="Gray" 
                       VerticalAlignment="Center" Margin="20,0,0,0" IsHitTestVisible="False"/>

            <!-- Filter Dropdown -->
            <ComboBox x:Name="FilterBox"
          SelectionChanged="FilterBox_SelectionChanged"
          Width="180" Height="30"
          VerticalAlignment="Center"
          HorizontalAlignment="Right"
          Background="#222"
          Foreground="Black"
          Margin="100,0,-150,0">
            </ComboBox>


        </Grid>

        <!-- Movie Grid -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10,260,10,10">
            <WrapPanel x:Name="MovieWrap"/>

        </ScrollViewer>

    </Grid>
</UserControl>
