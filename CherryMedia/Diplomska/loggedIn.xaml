<UserControl x:Class="Diplomska.loggedIn"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Diplomska"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- Prilagojen slog za gumbe -->
        <Style x:Key="HoverButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#426EB5" />
            <!-- Privzeta temna modra -->
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="Width" Value="150" />
            <Setter Property="Height" Value="100" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="Black" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Ob hoverju spremeni barvo -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A7ACF" />
                    <!-- Svetlejša temno modra ob hoverju -->
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#242e49" Offset="0.0" />
                <GradientStop Color="#37415c" Offset="0.33" />
                <GradientStop Color="#181a2f" Offset="0.66" />
                <GradientStop Color="#54162b" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Dobrodošli!" FontSize="28" FontWeight="Bold" Foreground="White" TextAlignment="Center" Margin="0 0 0 20" />
            <TextBlock Text="Izberite spodnji opciji:" FontSize="16" Foreground="LightGray" TextAlignment="Center" Margin="0 0 0 10" />

            <!-- Gumbi z hover efektom -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="CherryNote" Style="{StaticResource HoverButtonStyle}" Click="SpotifyButton_Click" />
                <Button Content="CherryFrame" Style="{StaticResource HoverButtonStyle}" Click="FilmiButton_Click" />
            </StackPanel>

            <!-- Logout gumb -->
            <Button Width="200" Height="50" Background="OrangeRed" Foreground="White" Content="LOGOUT"
                    FontWeight="Bold" Margin="20" Style="{StaticResource HoverButtonStyle}" Click="LogoutButton_Click" />
        </StackPanel>
    </Grid>
</UserControl>
