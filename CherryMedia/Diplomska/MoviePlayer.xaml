<UserControl x:Class="Diplomska.MoviePlayer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Black">
    <Grid>
        <!-- Media Element -->
        <MediaElement Name="Player"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Stop"
                      Stretch="Uniform"
                      Margin="10"/>


        <!-- Playback Controls -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,60">
            <Button x:Name="reverseButton" Content="⏪ 30s" Width="80" Margin="5" Click="Rewind_Click"/>
            <Button x:Name="PlayPauseButton" Content="▶️" Width="80" Margin="5" Click="PlayPause_Click"/>
            <Button x:Name="forwardButton" Content="30s ⏩" Width="80" Margin="5" Click="Forward_Click"/>
            <Button x:Name="FullScreenButton" Content="📺 Fullscreen" Width="100" Margin="5" Click="FullScreen_Click"/>
        </StackPanel>

        <!-- Progress Slider -->
        <Slider x:Name="ProgressSlider"
                VerticalAlignment="Bottom"
                Height="30"
                Margin="20"
                Minimum="0"
                Maximum="100"
                ValueChanged="ProgressSlider_ValueChanged"
                PreviewMouseLeftButtonDown="ProgressSlider_PreviewMouseLeftButtonDown"
                PreviewMouseLeftButtonUp="ProgressSlider_MouseLeftButtonUp"/>
        
        
    </Grid>
</UserControl>